{
  "name": "@platforma-open/milaboratories.clonotype-clustering.workflow",
  "version": "4.2.5",
  "private": true,
  "description": "Tengo-based template",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && pl-tengo build",
    "format": "/usr/bin/env emacs --script ./format.el || echo 'No emacs.'",
    "do-pack": "shx rm -f *.tgz && pnpm pack && shx mv *.tgz package.tgz",
    "check": "pl-tengo check"
  },
  "dependencies": {
    "@platforma-open/milaboratories.clonotype-clustering.software": "workspace:*",
    "@platforma-open/soedinglab.software-mmseqs2": "catalog:",
    "@platforma-sdk/workflow-tengo": "catalog:"
  },
  "devDependencies": {
    "@platforma-sdk/tengo-builder": "catalog:",
    "@platforma-sdk/test": "catalog:",
    "shx": "catalog:"
  }
}
